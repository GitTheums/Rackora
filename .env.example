# Application
NODE_ENV=development
PORT=7575
HOST=0.0.0.0
APP_URL=http://localhost:7575
LOG_LEVEL=info

# Database (paths are resolved from the monorepo root)
DATA_DIR=./data
# DATABASE_PATH=./data/rackora.db

# 32-byte key as 64-character hex or base64
MASTER_ENCRYPTION_KEY=

# Allow per-integration insecure TLS (self-signed Proxmox). Default false.
# Even when true, each integration must explicitly set tlsMode=insecure.
ALLOW_INSECURE_TLS=false
